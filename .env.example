# Copy to .env for local development. Set as Fly secrets in production.
# fly secrets set ANTHROPIC_API_KEY=sk-ant-... DEPOSIT_WALLET_KEY=0x...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Base network
# The private key of the wallet that receives deposits.
# Generate a fresh wallet exclusively for this purpose.
DEPOSIT_WALLET_KEY=0x_your_deposit_wallet_private_key
DEPOSIT_WALLET_ADDRESS=0x_your_deposit_wallet_address

# Base mainnet RPC — use a dedicated node provider (Alchemy, QuickNode, or Coinbase)
# for reliable tx detection. Public RPCs rate-limit aggressively.
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key-here

# Deposit amount in ETH (exact, no tolerance below this)
DEPOSIT_AMOUNT_ETH=0.002

# SQLite database path
DB_PATH=/data/substitute.db

# API
PORT=3000

# Optional: HMAC secret for callback signature headers
CALLBACK_HMAC_SECRET=generate-a-random-32-char-string-here

# Queue limits
MAX_QUEUE_SIZE=50
REGISTRATION_EXPIRY_MINUTES=30
