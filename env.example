# ── Project Substitute — Local Environment ────────────────────────────────────
# Location: substitute-backend/.env  (same folder as package.json)
# Purpose:  Local scripts only (e.g. attest.js). Never deployed to Fly.
#           Fly uses secrets set via: fly secrets set KEY=value
#
# To use: copy this file to .env and fill in real values.
#   cp .env.example .env
# Then edit .env with your actual credentials.
#
# NEVER commit .env to git. Add it to .gitignore if using version control.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key
# Get from: console.anthropic.com → API Keys → Create new key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Base wallet — the wallet that receives deposits and signs attestations
# Generate a fresh wallet exclusively for this service
# Get address and private key from MetaMask or Coinbase Wallet
DEPOSIT_WALLET_ADDRESS=0x_your_deposit_wallet_address
DEPOSIT_WALLET_KEY=0x_your_deposit_wallet_private_key

# Base mainnet RPC URL
# Get from: alchemy.com → create app → Base Mainnet → API Key → HTTPS
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-alchemy-key-here

# Deposit amount in ETH (must match what is published in the manifest)
DEPOSIT_AMOUNT_ETH=0.002

# Public URL of the deployed API (no trailing slash)
API_BASE_URL=https://zero-wispy-shadow-3951.fly.dev

# SQLite path — only relevant if running api.js or runner.js locally
DB_PATH=./substitute.db

# HMAC secret for signing callback payloads
# Generate with: openssl rand -hex 16
CALLBACK_HMAC_SECRET=your-32-char-random-string-here

# Set after running attest.js — paste the UID printed by the script
# Then also set as a Fly secret: fly secrets set EAS_ATTESTATION_UID=0x...
EAS_ATTESTATION_UID=
